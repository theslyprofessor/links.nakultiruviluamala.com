---
import data from '../data/links.json';

const { profile, categories } = data;

// PostHog public (phc_) project key — client-safe, visible in page source by design.
// Override at build with PUBLIC_POSTHOG_KEY; set to '' to disable tracking.
const POSTHOG_KEY = import.meta.env.PUBLIC_POSTHOG_KEY ?? 'phc_qgoLdK3kMnSGtzsNaoN9NgnRXotfoYjytCjGk3Nd2b3j';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{profile.name} — Links</title>
    <meta name="description" content={`${profile.name} — ${profile.tagline}`} />

    <!-- Open Graph / social preview -->
    <meta property="og:title" content={`${profile.name} — Links`} />
    <meta property="og:description" content={profile.tagline} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://links.nakultiruviluamala.com" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600&family=IBM+Plex+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <style>
      :root {
        color-scheme: dark;
        --bg: #171310;
        --bg-lift: #1e1915;
        --ink: #f0e7d8;
        --ink-dim: rgba(240, 231, 216, 0.62);
        --ink-faint: rgba(240, 231, 216, 0.38);
        --amber: #e8a04c;
        --amber-glow: rgba(232, 160, 76, 0.35);
        --hairline: rgba(240, 231, 216, 0.12);
      }

      * { box-sizing: border-box; }

      body {
        margin: 0;
        min-height: 100vh;
        font-family: "IBM Plex Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
        color: var(--ink);
        background:
          /* faint horizontal panel-line texture */
          repeating-linear-gradient(
            180deg,
            rgba(255, 255, 255, 0.012) 0px,
            rgba(255, 255, 255, 0.012) 1px,
            transparent 1px,
            transparent 4px
          ),
          /* warm VU-backlight pool at the top */
          radial-gradient(900px 480px at 50% -8%, rgba(232, 160, 76, 0.14), transparent 65%),
          /* warm brown-to-charcoal room */
          linear-gradient(180deg, #1c1712 0%, var(--bg) 40%, #131009 100%);
        display: flex;
        justify-content: center;
        padding: 56px 20px 88px;
        -webkit-font-smoothing: antialiased;
      }

      .console {
        width: 100%;
        max-width: 620px;
      }

      /* ---------- header ---------- */
      header {
        text-align: center;
        margin-bottom: 44px;
      }

      .avatar {
        width: 96px;
        height: 96px;
        border-radius: 50%;
        object-fit: cover;
        margin: 0 auto 18px;
        display: block;
        border: 1px solid rgba(232, 160, 76, 0.5);
        box-shadow:
          0 0 0 5px rgba(232, 160, 76, 0.08),
          0 0 32px var(--amber-glow),
          0 8px 28px rgba(0, 0, 0, 0.55);
        background: var(--bg-lift);
      }

      h1 {
        font-family: "Fraunces", Georgia, serif;
        font-weight: 600;
        font-size: 1.7rem;
        letter-spacing: 0.01em;
        margin: 0 0 10px;
      }

      .tagline {
        margin: 0;
        font-size: 0.72rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--ink-dim);
      }

      /* rec-light divider under the header */
      .rec-strip {
        display: flex;
        align-items: center;
        gap: 12px;
        margin: 26px 0 0;
      }
      .rec-strip::before,
      .rec-strip::after {
        content: "";
        flex: 1;
        height: 1px;
        background: linear-gradient(90deg, transparent, var(--hairline));
      }
      .rec-strip::after {
        background: linear-gradient(90deg, var(--hairline), transparent);
      }
      .rec-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: var(--amber);
        box-shadow: 0 0 10px var(--amber-glow), 0 0 3px var(--amber);
      }

      /* ---------- channel-strip sections ---------- */
      section {
        margin-top: 40px;
      }

      .strip-label {
        display: flex;
        align-items: baseline;
        gap: 14px;
        margin: 0 0 16px;
      }

      .strip-label h2 {
        margin: 0;
        font-size: 0.7rem;
        font-weight: 500;
        letter-spacing: 0.28em;
        text-transform: uppercase;
        color: var(--amber);
        white-space: nowrap;
      }

      .strip-label .ch {
        font-size: 0.62rem;
        letter-spacing: 0.12em;
        color: var(--ink-faint);
        white-space: nowrap;
      }

      .strip-label::after {
        content: "";
        flex: 1;
        height: 1px;
        align-self: center;
        background: linear-gradient(90deg, var(--hairline), transparent);
      }

      /* ---------- link rows ---------- */
      .rows {
        display: flex;
        flex-direction: column;
        gap: 10px;
      }

      .link {
        position: relative;
        display: block;
        text-decoration: none;
        color: inherit;
        padding: 15px 18px 17px;
        border-radius: 10px;
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.028), rgba(255, 255, 255, 0.008));
        border: 1px solid var(--hairline);
        overflow: hidden;
        transition: border-color 0.18s ease, background-color 0.18s ease, transform 0.18s ease;
      }

      /* fader-style amber underline that rides up on hover */
      .link::after {
        content: "";
        position: absolute;
        left: 18px;
        right: 18px;
        bottom: 9px;
        height: 2px;
        border-radius: 2px;
        background: linear-gradient(90deg, var(--amber), rgba(232, 160, 76, 0.15));
        transform: scaleX(0.18);
        transform-origin: left center;
        opacity: 0.55;
        transition: transform 0.28s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.28s ease;
      }

      .link:hover,
      .link:focus-visible {
        border-color: rgba(232, 160, 76, 0.45);
        transform: translateY(-1px);
        outline: none;
      }

      .link:hover::after,
      .link:focus-visible::after {
        transform: scaleX(1);
        opacity: 1;
        box-shadow: 0 0 12px var(--amber-glow);
      }

      .link:active {
        transform: translateY(0);
      }

      .link .row-top {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 12px;
      }

      .link .label {
        font-family: "Fraunces", Georgia, serif;
        font-weight: 600;
        font-size: 1.05rem;
        letter-spacing: 0.01em;
      }

      .link .arrow {
        font-size: 0.78rem;
        color: var(--ink-faint);
        transition: color 0.18s ease, transform 0.18s ease;
      }

      .link:hover .arrow,
      .link:focus-visible .arrow {
        color: var(--amber);
        transform: translateX(2px);
      }

      .link .desc {
        display: block;
        margin-top: 5px;
        font-size: 0.76rem;
        line-height: 1.5;
        color: var(--ink-dim);
        padding-bottom: 8px; /* room for the fader line */
      }

      /* ---------- footer ---------- */
      footer {
        margin-top: 56px;
        text-align: center;
        font-size: 0.66rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--ink-faint);
      }

      @media (min-width: 640px) {
        body { padding-top: 72px; }
        h1 { font-size: 1.95rem; }
        .link { padding: 17px 22px 19px; }
        .link::after { left: 22px; right: 22px; }
      }

      @media (prefers-reduced-motion: reduce) {
        .link, .link::after, .link .arrow { transition: none; }
      }
    </style>
  </head>
  <body>
    <main class="console">
      <header>
        <img class="avatar" src={profile.avatar} alt={profile.name} onerror="this.style.visibility='hidden'" />
        <h1>{profile.name}</h1>
        <p class="tagline">{profile.tagline}</p>
        <div class="rec-strip" aria-hidden="true"><span class="rec-dot"></span></div>
      </header>

      {categories.map((category, i) => (
        <section>
          <div class="strip-label">
            <span class="ch">CH {String(i + 1).padStart(2, '0')}</span>
            <h2>{category.title}</h2>
          </div>
          <div class="rows">
            {category.links.map((link) => (
              <a
                class="link"
                href={link.url}
                target="_blank"
                rel="noopener noreferrer"
                data-label={link.label}
              >
                <span class="row-top">
                  <span class="label">{link.label}</span>
                  <span class="arrow">→</span>
                </span>
                <span class="desc">{link.description}</span>
              </a>
            ))}
          </div>
        </section>
      ))}

      <footer>
        © {new Date().getFullYear()} {profile.name}
      </footer>
    </main>

    {POSTHOG_KEY && (
      <script is:inline define:vars={{ POSTHOG_KEY }}>
        !function(t,e){var o,n,p,r;e.__SV||(window.posthog=e,e._i=[],e.init=function(i,s,a){function g(t,e){var o=e.split(".");2==o.length&&(t=t[o[0]],e=o[1]),t[e]=function(){t.push([e].concat(Array.prototype.slice.call(arguments,0)))}}(p=t.createElement("script")).type="text/javascript",p.async=!0,p.src=s.api_host+"/static/array.js",(r=t.getElementsByTagName("script")[0]).parentNode.insertBefore(p,r);var u=e;for(void 0!==a?u=e[a]=[]:a="posthog",u.people=u.people||[],u.toString=function(t){var e="posthog";return"posthog"!==a&&(e+="."+a),t||(e+=" (stub)"),e},u.people.toString=function(){return u.toString(1)+".people (stub)"},o="capture identify alias people.set people.set_once set_config register register_once unregister opt_out_capturing has_opted_out_capturing opt_in_capturing reset isFeatureEnabled onFeatureFlags getFeatureFlag getFeatureFlagPayload reloadFeatureFlags group updateEarlyAccessFeatureEnrollment getEarlyAccessFeatures getActiveMatchingSurveys getSurveys getNextSurveyStep".split(" "),n=0;n<o.length;n++)g(u,o[n]);e._i.push([i,s,a])},e.__SV=1)}(document,window.posthog||[]);
        posthog.init(POSTHOG_KEY, { api_host: 'https://us.i.posthog.com' });
        document.querySelectorAll('.link').forEach(function(el){
          el.addEventListener('click', function(){
            posthog.capture('link_click', { label: el.dataset.label, url: el.href });
          });
        });
      </script>
    )}
  </body>
</html>
